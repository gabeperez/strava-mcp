# Strava MCP OAuth Server - Environment Variables

# Strava OAuth Application Credentials
# Get these from: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id_here
STRAVA_CLIENT_SECRET=your_strava_client_secret_here

# OAuth Redirect URI (set this to your deployed worker URL + /callback)
STRAVA_REDIRECT_URI=https://your-worker-name.your-subdomain.workers.dev/callback

# Example for this deployment:
# STRAVA_REDIRECT_URI=https://strava-mcp-oauth.perez-jg22.workers.dev/callback

# Note: These are set as Cloudflare Workers secrets using:
# wrangler secret put STRAVA_CLIENT_ID
# wrangler secret put STRAVA_CLIENT_SECRET

# The STRAVA_REDIRECT_URI is set in wrangler.jsonc as a regular variable